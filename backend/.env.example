# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hemodialysis_db
DB_USER=hd_app
DB_PASSWORD=your_db_password_here
DB_POOL_MAX=10
# 可选：创建/删除临时库时连接的管理库（默认 postgres）
# DB_ADMIN_DATABASE=postgres
# 可选：PostgreSQL 命令行工具目录（未设置时默认使用系统 PATH）
# PG_BIN_DIR=C:\Program Files\PostgreSQL\16\bin

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# JWT配置
JWT_SECRET=your_64_byte_hex_jwt_secret_here
JWT_EXPIRES_IN=12h

# 数据加密（患者身份证/手机号）
ENCRYPT_KEY=your_32_byte_hex_key_here

# 服务器（若本机 netsh 显示 2977–3076 为排除范围，请改用 3080 等端口，避免 EACCES）
PORT=3080
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 登录安全（Redis 可用时多实例共享，Redis 不可用则退回单机内存）
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=30
# 开发/演示种子脚本默认密码（运行 seedUsers.js 时必填，至少6位字母数字）
SEED_DEFAULT_PASSWORD=your_seed_password_here

# AI服务（通义千问：QWEN_API_KEY 或兼容 AI_API_KEY；模型默认 qwen3-max）
# 注意：示例文件仅保留占位值，真实密钥只应写入本地/部署环境的 .env
AI_PROVIDER=qwen3-max
AI_MODEL=qwen3-max
QWEN_MODEL=qwen3-max
QWEN_API_KEY=your_qwen_api_key_here
AI_API_KEY=your_ai_api_key_here
# 调用通义 HTTP 超时（毫秒），默认 90000；与前端 AI 请求 90s 对齐（上限 120000）
QWEN_HTTP_TIMEOUT_MS=90000
AI_HTTP_TIMEOUT_MS=90000
# 深度推理（DashScope 兼容接口支持时生效；若接口报错将自动重试去掉该参数）
AI_ENABLE_THINKING=true

# 月度质控 AI 解读（聚合月报，无患者标识）；设为 false 可关闭接口
AI_QC_MONTHLY_INSIGHT_ENABLED=true

# 资料库不足时是否允许联网补全（默认关闭，需自行实现外部搜索）
WEB_SEARCH_ENABLED=false

# 阿里云OSS（备份）
OSS_REGION=cn-beijing
OSS_BUCKET=hemodialysis-backup
OSS_ACCESS_KEY=your_oss_access_key
OSS_ACCESS_SECRET=your_oss_access_secret

# 短信（预留）
SMS_PROVIDER=
SMS_API_KEY=

# 可选：CLI 导入患者 scripts/import-patients-from-xlsx.js 的 created_by 用户 UUID（不设则取首个启用管理员）
# IMPORT_ACTOR_USER_ID=
