# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hemodialysis_db
DB_USER=hd_app
DB_PASSWORD=your_strong_password_here
DB_POOL_MAX=10

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# JWT配置
JWT_SECRET=your_64_byte_hex_jwt_secret_here
JWT_EXPIRES_IN=12h

# 数据加密（患者身份证/手机号）
ENCRYPT_KEY=your_32_byte_hex_key_here

# 服务器
PORT=3000
NODE_ENV=development

# AI服务
AI_PROVIDER=deepseek
AI_API_KEY=your_ai_api_key_here

# 阿里云OSS（备份）
OSS_REGION=cn-beijing
OSS_BUCKET=hemodialysis-backup
OSS_ACCESS_KEY=your_oss_access_key
OSS_ACCESS_SECRET=your_oss_access_secret

# 短信（预留）
SMS_PROVIDER=
SMS_API_KEY=
